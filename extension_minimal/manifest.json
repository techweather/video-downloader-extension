{
  "manifest_version": 2,
  "name": "Media Downloader Connector",
  "version": "2.0",
  "description": "Send media URLs to native downloader app",
  "permissions": [
    "contextMenus",
    "activeTab",
    "nativeMessaging",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}